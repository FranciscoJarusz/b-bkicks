<section class="relative w-full h-80 lg:min-h-120 overflow-hidden">

    <img
        src="/hero.webp"
        alt="Imágen Hero"
        class="w-full h-full object-cover absolute inset-0"
        fetchpriority="high"
    />

    <div class="absolute inset-0 bg-black/85"></div>

    <div class="absolute inset-0 z-10 flex flex-col items-start justify-center text-start px-6 py-16 sm:py-0 max-w-7xl mx-auto gap-4 animate-fade-in-down">
        <h1 class="text-5xl sm:text-6xl md:text-8xl font-semibold text-white uppercase font-accent italic leading-tight">
            SNEAKERS Y STREETWEAR
        </h1>

        <p class="text-sm sm:text-base text-white/80 animate-fade-in-down animate-delay-200">
            Expertos en reventa de piezas exclusivas.<br>
            Desde 2020 brindando seguridad y autenticidad en cada par.
        </p>

        <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 w-full sm:w-auto mt-2 animate-fade-in-down animate-delay-500">
            <a href="/busqueda" class="bg-primary text-secondary font-semibold px-5 py-2 rounded-full text-sm hover:bg-primary-accent transition-all duration-300 flex items-center text-center justify-center">
                Conocé todos nuestros productos
            </a>      

            <a href="#encargos" class="group ring-2 ring-primary ring-inset text-secondary font-semibold px-5 py-2 rounded-full text-sm hover:bg-primary transition-colors duration-300 text-center flex items-center justify-center gap-3">
                <svg
                    id="avion-hero"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-6 h-6 rotate-45"
                >
                    <path id="avion-p1" d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
                </svg>

                Cómo encargar
            </a>                  
        </div>
        
    </div>

</section>



<script is:inline>
    const path = document.getElementById('avion-p1');
    const btn = document.getElementById('avion-hero').closest('a');

    btn.addEventListener('mouseenter', () => {
        const len = path.getTotalLength();
        path.style.transition = 'none';
        path.style.strokeDasharray = len;
        path.style.strokeDashoffset = len;
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                path.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
                path.style.strokeDashoffset = '0';
            });
        });
    });
</script>