<section class="relative w-full min-h-80 overflow-hidden lg:min-h-100">
    <img
        src="/hero.webp"
        alt="Imagen Hero"
        class="absolute inset-0 h-full w-full object-cover object-center"
        fetchpriority="high"
    />

    <div class="absolute inset-0 bg-black/78 sm:bg-black/82"></div>

    <div class="relative z-10 mx-auto flex min-h-[68svh] max-w-7xl flex-col items-start justify-center gap-5 px-6 py-12 text-start animate-fade-in-down sm:gap-6 sm:py-16 lg:gap-7 lg:px-8">
        <h1 class="max-w-[10ch] text-[3.35rem] leading-[0.9] tracking-[0.02em] text-secondary uppercase font-accent sm:max-w-[12ch] sm:text-7xl md:text-[5.5rem] lg:max-w-[13ch] lg:text-[7rem]">
            SNEAKERS Y STREETWEAR
        </h1>

        <div class="max-w-xl space-y-3 text-base leading-7 text-secondary/82 sm:text-lg">
            <p class="animate-fade-in-down animate-delay-200">
                Desde 2024 brindando acceso a lo mas exclusivo del streetwear.
            </p>
            <p class="animate-fade-in-down animate-delay-200">
                Expertos en piezas originales y drops exclusivos.
            </p>
        </div>

        <div class="mt-2 flex w-full max-w-md flex-col gap-3 animate-fade-in-down animate-delay-500 sm:max-w-none sm:flex-row sm:gap-4">
            <a href="/busqueda" class="flex min-h-10 items-center justify-center rounded-full bg-primary px-6 py-3 text-center text-base font-semibold text-secondary transition-all duration-300 hover:bg-primary-accent sm:min-w-52">
                Ver Catalogo
            </a>

            <a href="#encargos" class="group flex min-h-10 items-center justify-center gap-3 rounded-full px-6 py-3 text-center text-base font-semibold text-secondary ring-2 ring-primary ring-inset transition-colors duration-300 hover:bg-primary sm:min-w-52">
                <svg
                    id="avion-hero"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-6 w-6 shrink-0 rotate-45"
                >
                    <path id="avion-p1" d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
                </svg>

                Como encargar
            </a>
        </div>
    </div>
</section>

<script is:inline>
    const path = document.getElementById('avion-p1');
    const icon = document.getElementById('avion-hero');
    const btn = icon?.closest('a');

    if (path && btn) {
        btn.addEventListener('mouseenter', () => {
            const len = path.getTotalLength();
            path.style.transition = 'none';
            path.style.strokeDasharray = len;
            path.style.strokeDashoffset = len;
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    path.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1)';
                    path.style.strokeDashoffset = '0';
                });
            });
        });
    }
</script>
