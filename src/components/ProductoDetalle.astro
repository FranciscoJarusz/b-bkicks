---
const { producto } = Astro.props;
---

<main class="max-w-4xl mx-auto px-6 py-16">

  <a href="/" class="text-sm text-gray-500 hover:text-primary mb-8 inline-block">← Volver al catálogo</a>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-6">

    <div class="bg-gray-100 rounded-2xl flex items-center justify-center h-80">
      {producto.image
        ? <img src={producto.image} alt={producto.name} class="object-contain h-full w-full p-6" />
        : <span class="text-gray-400 text-sm">Sin imagen</span>
      }
    </div>

    <div class="flex flex-col gap-4">

      {(producto.category || producto.marca) && (
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-400">
          {[producto.category, producto.marca].filter(Boolean).join(" ")}
        </span>
      )}

      <h1 class="text-3xl font-bold text-gray-900">{producto.name}</h1>

      {producto.description && (
        <p class="text-gray-500 text-sm leading-relaxed">{producto.description}</p>
      )}

      {producto.specs?.talle?.length > 0 && (
        <div>
          <p class="text-xs font-semibold uppercase text-gray-400 mb-2">Talles</p>
          <div class="flex flex-wrap gap-2">
            {producto.specs.talle.map((t: string) => (
              <span class="border border-gray-300 text-gray-600 text-sm px-3 py-1 rounded-full">{t}</span>
            ))}
          </div>
        </div>
      )}

      <span class="text-2xl font-bold text-gray-900 mt-2">
        ${producto.price.toLocaleString("es-AR")}
      </span>

      <button
        class="w-full bg-primary hover:bg-primary-accent text-white font-semibold py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        disabled={producto.stock === 0}
      >
        {producto.stock === 0 ? "Sin stock" : "Agregar al carrito"}
      </button>

    </div>

  </div>

</main>
