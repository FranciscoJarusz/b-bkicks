---
import AgregarAlCarrito from './ui/AgregarAlCarrito.jsx';
import GaleriaImagenes from './ui/GaleriaImagenes.jsx';

interface Props {
    producto: {
        name: string;
        slug: string;
        image: string;
        images?: string[];
        category: string;
        marca: string;
        description: string;
        price: number;
        stock: number;
        specs: { talle: { nombre: string; stock: number }[] | string[] };
    };
} 

const { producto } = Astro.props;
---

<section class="px-6 py-16 max-w-7xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-6">

        <GaleriaImagenes
            images={producto.images?.length ? producto.images : (producto.image ? [producto.image] : [])}
            alt={producto.name}
            client:load
        />
        
        <div class="flex flex-col gap-10">

            <div class="flex flex-col gap-4">
                <a href="/" class="flex items-center gap-1.5 text-sm text-gray/80 hover:text-primary w-fit transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
                    </svg>
                    Volver al catálogo
                </a>

                {(producto.category || producto.marca) && (
                    <span class="text-xs font-semibold uppercase tracking-wide text-gray/50">
                    {[producto.category, producto.marca].filter(Boolean).join(" ")}
                    </span>
                )}

                <h1 class="text-3xl font-bold text-black">{producto.name}</h1>                
            </div>


            <span class="text-2xl font-bold text-black">
                ${producto.price.toLocaleString("es-AR")}
            </span>

            <AgregarAlCarrito producto={producto} client:load />

        </div>

    </div>

</section>