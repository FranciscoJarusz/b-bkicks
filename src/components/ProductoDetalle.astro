---
import AgregarAlCarrito from '@/components/ui/AgregarAlCarrito.jsx';
import GaleriaImagenes from '@/components/ui/GaleriaImagenes.jsx';

interface Props {
    producto: {
        name: string;
        slug: string;
        image: string;
        images?: string[];
        category: string;
        marca: string;
        description: string;
        price: number;
        stock: number;
        specs: { talle: { nombre: string; stock: number }[] | string[] };
    };
} 

const { producto } = Astro.props;
---

<section class="px-6 py-16 max-w-7xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-6">

        <GaleriaImagenes
            images={producto.images?.length ? producto.images : (producto.image ? [producto.image] : [])}
            alt={producto.name}
            client:load
        />
        
        <div class="flex flex-col gap-6">

            <div class="flex flex-col gap-4">
                <a href="/" class="flex items-center gap-1.5 text-sm text-gray-accent hover:text-primary w-fit transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
                    </svg>
                    Volver al inicio
                </a>

                {(producto.category || producto.marca) && (
                    <span class="text-xs font-semibold uppercase tracking-wide text-gray-accent">
                    {[producto.category, producto.marca].filter(Boolean).join(" ")}
                    </span>
                )}

                <h1 class="text-4xl font-bold text-black">{producto.name}</h1>                
            </div>

            <div class="flex flex-col gap-8">
                <span class="text-2xl font-bold text-black">
                    ${producto.price.toLocaleString("es-AR")}
                </span>

                <div class="flex items-center gap-2 text-sm text-primary">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 -64 640 640" xmlns="http://www.w3.org/2000/svg">
                        <path d="M624 352h-16V243.9c0-12.7-5.1-24.9-14.1-33.9L494 110.1c-9-9-21.2-14.1-33.9-14.1H416V48c0-26.5-21.5-48-48-48H112C85.5 0 64 21.5 64 48v48H8c-4.4 0-8 3.6-8 8v16c0 4.4 3.6 8 8 8h272c4.4 0 8 3.6 8 8v16c0 4.4-3.6 8-8 8H40c-4.4 0-8 3.6-8 8v16c0 4.4 3.6 8 8 8h208c4.4 0 8 3.6 8 8v16c0 4.4-3.6 8-8 8H8c-4.4 0-8 3.6-8 8v16c0 4.4 3.6 8 8 8h208c4.4 0 8 3.6 8 8v16c0 4.4-3.6 8-8 8H64v128c0 53 43 96 96 96s96-43 96-96h128c0 53 43 96 96 96s96-43 96-96h48c8.8 0 16-7.2 16-16v-32c0-8.8-7.2-16-16-16zM160 464c-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48-21.5 48-48 48zm320 0c-26.5 0-48-21.5-48-48s21.5-48 48-48 48 21.5 48 48-21.5 48-48 48zm80-208H416V144h44.1l99.9 99.9V256z"/>
                    </svg>
                    Envíos a todo el país
                </div>
            </div>

            <AgregarAlCarrito producto={producto} client:load />

        </div>

    </div>

</section>