---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import ResultadosBusqueda from '@/components/ui/ResultadosBusqueda.jsx';
import { getProductosAgrupados } from '@/utils/productos.js';

const productos = await getProductosAgrupados();
---

<Layout
    title="Búsqueda de Productos"
    description="Buscá sneakers y streetwear en B&B KICKS. Encontrá zapatillas de las mejores marcas con envíos a todo el país."
>
    {productos[0]?.image && (
        <link slot="head" rel="preload" as="image" href={productos[0].image} fetchpriority="high" />
    )}
    <Header />

    <ResultadosBusqueda productos={productos} client:load />
</Layout>
