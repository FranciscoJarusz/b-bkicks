---
import '@/styles/global.css';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  hideFooter?: boolean;
  disableSmoothScroll?: boolean;
}

const { title, description, ogImage, noindex = false, hideFooter = false, disableSmoothScroll = false } = Astro.props;

const pageTitle = title
  ? `${title} - B&B KICKS`
  : 'B&B KICKS - Sneakers y Streetwear en Buenos Aires';

const pageDescription = description
  ?? 'B&B Kicks: Tu tienda de confianza para sneakers y streetwear de tendencia. 100% original, atención personalizada por WhatsApp y envíos rápidos a toda Argentina. Entrá y mirá más.';

const pageImage = ogImage ?? '/og-image.jpg';
---

<!doctype html>

<html lang="es">

	<head>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<meta name="description" content={pageDescription} />
		<meta name="author" content="B&B KICKS" />
		<meta name="keywords" content="sneakers, zapatillas, streetwear, ropa, Buenos Aires, tienda online, corteiz, nike, adidas, noemotions, supreme, jordan" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="B&B KICKS" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={pageImage} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={pageImage} />

		<link rel="icon" type="image/svg+xml" href="/Logotipo.svg" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" /></noscript>

		<link rel="preconnect" href="https://use.typekit.net" />
		<link rel="preload" as="style" href="https://use.typekit.net/ots3kmz.css" onload="this.onload=null;this.rel='stylesheet'" />
		<noscript><link rel="stylesheet" href="https://use.typekit.net/ots3kmz.css" /></noscript>

		<title>{pageTitle}</title>
		<slot name="head" />

	</head>

	<body class="min-h-dvh flex flex-col"> 
		<main class="flex-1">
			<slot />
		</main>
		{!hideFooter && <Footer />}
	</body>
	
	<link/>
	{!disableSmoothScroll && (
		<script>
			import '@/scripts/lenis.ts';
		</script>
	)}
</html>
